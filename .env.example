# 0G Chain (testnet)
OG_RPC_URL=https://evmrpc-testnet.0g.ai
OG_CHAIN_ID=16602
OG_EXPLORER=https://chainscan-galileo.0g.ai
PRIVATE_KEY=0x...

# 0G Storage
OG_STORAGE_INDEXER=https://indexer-storage-testnet-turbo.0g.ai

# 0G Compute / Sealed Inference
# (broker is initialized from wallet; no fixed endpoint var)

# Backend
PORT=4000
NODE_ENV=development

# Encryption key derivation — REQUIRED for persistent memories across restarts.
# Generate once: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# WARNING: changing this makes all existing encrypted memories unreadable.
KEY_DERIVATION_SECRET=

# Deployed contracts (filled after Phase 1 deploy)
SEALED_MIND_NFT_ADDRESS=
CAPABILITY_REGISTRY_ADDRESS=
MEMORY_ACCESS_LOG_ADDRESS=
